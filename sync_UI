"""
Sync UI - File synchronization client with GUI
"""

import tkinter as tk
from tkinter import ttk, messagebox, filedialog
import http.client
import json
import os
import zipfile
import threading


class SyncApp:
    def __init__(self, root):
        self.root = root
        self.root.title("File Sync Client v1.0")
        self.root.geometry("450x380")
        self.root.resizable(False, False)

        self.server_ip = tk.StringVar(value="192.168.0.109")
        self.server_port = tk.IntVar(value=5000)
        self.login = tk.StringVar()
        self.password = tk.StringVar()
        self.download_folder = tk.StringVar(value="./sync_downloads")

        self.folders = []
        self.user_folders = []

        self.setup_ui()

    def setup_ui(self):
        style = ttk.Style()
        style.configure("TLabel", font=("Segoe UI", 10))
        style.configure("TButton", font=("Segoe UI", 10))
        style.configure("Header.TLabel", font=("Segoe UI", 14, "bold"))

        main_frame = ttk.Frame(self.root, padding="20")
        main_frame.pack(fill=tk.BOTH, expand=True)

        header = ttk.Label(main_frame, text="🔄 File Sync Client", style="Header.TLabel")
        header.pack(pady=(0, 15))

        server_frame = ttk.LabelFrame(main_frame, text="Server", padding="10")
        server_frame.pack(fill=tk.X, pady=(0, 10))

        ttk.Label(server_frame, text="IP:").grid(row=0, column=0, sticky=tk.W, pady=5)
        ttk.Entry(server_frame, textvariable=self.server_ip, width=25).grid(row=0, column=1, pady=5, padx=5)

        ttk.Label(server_frame, text="Port:").grid(row=1, column=0, sticky=tk.W, pady=5)
        ttk.Entry(server_frame, textvariable=self.server_port, width=25).grid(row=1, column=1, pady=5, padx=5)

        auth_frame = ttk.LabelFrame(main_frame, text="Authentication", padding="10")
        auth_frame.pack(fill=tk.X, pady=(0, 10))

        ttk.Label(auth_frame, text="Login:").grid(row=0, column=0, sticky=tk.W, pady=5)
        ttk.Entry(auth_frame, textvariable=self.login, width=25).grid(row=0, column=1, pady=5, padx=5)

        ttk.Label(auth_frame, text="Password:").grid(row=1, column=0, sticky=tk.W, pady=5)
        ttk.Entry(auth_frame, textvariable=self.password, show="*", width=25).grid(row=1, column=1, pady=5, padx=5)

        folder_frame = ttk.LabelFrame(main_frame, text="Download Location", padding="10")
        folder_frame.pack(fill=tk.X, pady=(0, 10))

        ttk.Entry(folder_frame, textvariable=self.download_folder, width=30).grid(row=0, column=0, pady=5, padx=5)
        ttk.Button(folder_frame, text="Browse", command=self.browse_folder, width=10).grid(row=0, column=1, pady=5)

        self.status_label = ttk.Label(main_frame, text="Ready", foreground="gray")
        self.status_label.pack(pady=5)

        self.progress = ttk.Progressbar(main_frame, mode='indeterminate', length=400)
        self.progress.pack(pady=5)

        btn_frame = ttk.Frame(main_frame)
        btn_frame.pack(pady=10)

        self.login_btn = ttk.Button(btn_frame, text="🔑 Login", command=self.do_login, width=15)
        self.login_btn.pack(side=tk.LEFT, padx=5)

        self.sync_btn = ttk.Button(btn_frame, text="⬇️ Sync", command=self.do_sync, width=15, state=tk.DISABLED)
        self.sync_btn.pack(side=tk.LEFT, padx=5)

        self.folders_listbox = tk.Listbox(main_frame, selectmode=tk.MULTIPLE, height=6, font=("Consolas", 9))
        self.folders_listbox.pack(fill=tk.X, pady=5)

        scrollbar = ttk.Scrollbar(main_frame, orient=tk.VERTICAL, command=self.folders_listbox.yview)
        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
        self.folders_listbox.config(yscrollcommand=scrollbar.set)

    def browse_folder(self):
        folder = filedialog.askdirectory()
        if folder:
            self.download_folder.set(folder)

    def set_status(self, text, color="gray"):
        self.status_label.config(text=text, foreground=color)
        self.root.update()

    def start_progress(self):
        self.progress.start(10)

    def stop_progress(self):
        self.progress.stop()

    def do_login(self):
        if not self.login.get() or not self.password.get():
            messagebox.showwarning("Warning", "Please enter login and password")
            return

        thread = threading.Thread(target=self._login_thread, daemon=True)
        thread.start()

    def _login_thread(self):
        self.root.after(0, lambda: self.login_btn.config(state=tk.DISABLED))
        self.root.after(0, lambda: self.set_status("Connecting...", "blue"))
        self.root.after(0, self.start_progress)

        try:
            conn = http.client.HTTPConnection(self.server_ip.get(), self.server_port.get(), timeout=10)
            payload = json.dumps({
                'login': self.login.get(),
                'password': self.password.get()
            }).encode('utf-8')
            headers = {'Content-Type': 'application/json'}

            conn.request('POST', '/login', payload, headers)
            response = conn.getresponse()
            data = json.loads(response.read().decode('utf-8'))
            conn.close()

            if response.status == 200 and data.get('success'):
                self.user_folders = data.get('folders', [])
                self.root.after(0, self._login_success)
            else:
                error = data.get('error', 'Login failed')
                self.root.after(0, lambda: self._login_error(error))

        except Exception as e:
            self.root.after(0, lambda: self._login_error(str(e)))

    def _login_success(self):
        self.stop_progress()
        self.set_status(f"✓ Logged in as {self.login.get()}", "green")
        messagebox.showinfo("Success", f"Logged in!\nAvailable folders: {len(self.user_folders)}")

        self.folders_listbox.delete(0, tk.END)
        for folder in self.user_folders:
            self.folders_listbox.insert(tk.END, f"📁 {folder}")

        self.sync_btn.config(state=tk.NORMAL)
        self.login_btn.config(state=tk.DISABLED)

    def _login_error(self, error):
        self.stop_progress()
        self.set_status(f"✗ Error: {error}", "red")
        self.login_btn.config(state=tk.NORMAL)
        messagebox.showerror("Error", error)

    def do_sync(self):
        selected_indices = self.folders_listbox.curselection()
        if not selected_indices:
            messagebox.showwarning("Warning", "Select at least one folder to sync")
            return

        selected_folders = [self.user_folders[i] for i in selected_indices]

        thread = threading.Thread(target=self._sync_thread, args=(selected_folders,), daemon=True)
        thread.start()

    def _sync_thread(self, folders):
        self.root.after(0, lambda: self.sync_btn.config(state=tk.DISABLED))
        self.root.after(0, lambda: self.set_status("Downloading...", "blue"))
        self.root.after(0, self.start_progress)

        try:
            conn = http.client.HTTPConnection(self.server_ip.get(), self.server_port.get(), timeout=60)
            payload = json.dumps({
                'login': self.login.get(),
                'password': self.password.get(),
                'folders': folders
            }).encode('utf-8')
            headers = {'Content-Type': 'application/json'}

            conn.request('POST', '/download_sync', payload, headers)
            response = conn.getresponse()

            if response.status == 200:
                zip_data = response.read()
                self.root.after(0, lambda: self._save_zip(zip_data, folders))
            else:
                error = response.read().decode('utf-8')
                self.root.after(0, lambda: self._sync_error(error))

            conn.close()

        except Exception as e:
            self.root.after(0, lambda: self._sync_error(str(e)))

    def _save_zip(self, zip_data, folders):
        self.stop_progress()

        download_path = self.download_folder.get()
        if not os.path.exists(download_path):
            os.makedirs(download_path)

        zip_path = os.path.join(download_path, "sync_files.zip")
        with open(zip_path, 'wb') as f:
            f.write(zip_data)

        extract_path = os.path.join(download_path, "sync_data")
        if not os.path.exists(extract_path):
            os.makedirs(extract_path)

        with zipfile.ZipFile(zip_path, 'r') as zipf:
            zipf.extractall(extract_path)

        os.remove(zip_path)

        file_count = sum(len(files) for _, _, files in os.walk(extract_path))

        self.set_status(f"✓ Synced {len(folders)} folders ({file_count} files)", "green")
        self.sync_btn.config(state=tk.NORMAL)

        messagebox.showinfo("Success", f"Sync complete!\nFolders: {', '.join(folders)}\nFiles: {file_count}\nSaved to: {extract_path}")

    def _sync_error(self, error):
        self.stop_progress()
        self.set_status(f"✗ Error: {error}", "red")
        self.sync_btn.config(state=tk.NORMAL)
        messagebox.showerror("Error", error)


def main():
    root = tk.Tk()
    app = SyncApp(root)
    root.mainloop()


if __name__ == '__main__':
    main()
